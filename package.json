{
  "name": "pocketpanel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.840.0",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "gsap": "^3.14.2",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@aws-sdk/client-iam": "^3.1009.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.14",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
